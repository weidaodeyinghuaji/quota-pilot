{
  "name": "quota-pilot",
  "version": "0.3.1",
  "description": "Windows desktop dashboard for the active Codex account and API usage.",
  "private": false,
  "license": "MIT",
  "author": "Song Jianguo",
  "homepage": "https://github.com/weidaodeyinghuaji/quota-pilot#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/weidaodeyinghuaji/quota-pilot.git"
  },
  "bugs": {
    "url": "https://github.com/weidaodeyinghuaji/quota-pilot/issues"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "dev": "vite",
    "build": "vite build",
    "electron": "vite build && electron .",
    "dist": "node scripts/clean-generated.mjs && vite build && electron-builder --win",
    "dist:win": "node scripts/clean-generated.mjs && vite build && electron-builder --win",
    "clean:generated": "node scripts/clean-generated.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "ci": "npm run scan:secrets && npm test && npm run build"
  },
  "build": {
    "appId": "com.weidaodeyinghuaji.quotapilot",
    "productName": "QuotaPilot",
    "artifactName": "QuotaPilot-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "asar": true,
    "npmRebuild": false,
    "win": {
      "icon": "electron/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "include": "installer/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "QuotaPilot"
    },
    "portable": {
      "artifactName": "QuotaPilot-${version}-win-${arch}-portable.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "weidaodeyinghuaji",
        "repo": "quota-pilot"
      }
    ]
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
