{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Quota Glance",
  "version": "0.1.0",
  "identifier": "com.local.codex-quota-glance",
  "build": {
    "beforeDevCommand": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File .\\restart-local-server.ps1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Quota Glance",
        "width": 820,
        "height": 520,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
